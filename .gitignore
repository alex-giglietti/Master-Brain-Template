# ═══ ADMIN (never sent to clients) ═══
admin/

# ═══ CLIENT SECRETS (never commit) ═══
.client-key
.client-name
.cached-keyfile
.decrypted

# ═══ SOURCE FILES (admin local only) ═══
.source/

# ═══ DECRYPTED CONTENT (generated locally by decrypt.sh) ═══
# These are the .md files produced from .enc files — don't commit them
AGENTS.md
playbooks/**/*.md
execution/*.md
factory/*.md

# Keep templates and client-owned files
!brand/*.md
!vision/*.md
!custom-playbooks/*.md
!custom-playbooks/README.md
!START-HERE.md
!README.md
!SKILL.md

# ═══ CLIENT-OWNED (never overwritten by updates) ═══
# These are tracked as templates in the repo but
# client modifications are preserved during updates.
# memory/ contents are gitignored since they're per-client
memory/*.md
!memory/.gitkeep

# ═══ OS / misc ═══
.DS_Store
Thumbs.db
node_modules/
*.pyc
/tmp/
