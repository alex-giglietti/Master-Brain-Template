# GitHub Brain Configuration Template
# Copy this file to .env and fill in your actual values

# Your GitHub repository (username/repo-name)
GITHUB_BRAIN_REPO=your-username/your-brain-repo

# Branch to use (main, staging, dev, etc.)
GITHUB_BRAIN_BRANCH=main

# GitHub Personal Access Token (must have 'repo' scope)
# Generate at: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=ghp_your_token_here

# How often to sync from GitHub (in seconds)
# 300 = 5 minutes, 600 = 10 minutes
BRAIN_SYNC_INTERVAL=300

# Cache directory for brain files
BRAIN_CACHE_DIR=/tmp/openclaw_brain

# LLM Provider (optional - for bot runtime)
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
